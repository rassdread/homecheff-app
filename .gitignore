# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (NEVER commit these - contain sensitive API keys and secrets)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/app/generated/prisma

.vercel

# Firebase Android (lokaal plaatsen: android/app/google-services.json)
android/app/google-services.json

# Android release signing (lokaal: android/keystore.properties + android/*.jks)
android/keystore.properties
android/*.jks

# Sensitive files
STRIPE_KEYS.txt
*_KEYS.txt
*.key

# Gradle build cache (lokaal); Android Gradle-scripts staan wél in git (Capacitor).
.gradle/

# Local Play upload copies (scripts/release-android.mjs --play)
/release-artifacts/