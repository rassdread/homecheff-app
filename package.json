{
  "name": "homecheff-app",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "dev": "npm run clean && (lsof -ti:3000 | xargs kill -9 2>/dev/null; sleep 1) || true && next dev -p 3000 -H 0.0.0.0",
    "dev:fresh": "rm -rf .next && npm run dev",
    "dev:lan": "npm run dev",
    "build": "cross-env NODE_OPTIONS=--max-old-space-size=4096 NEXT_TELEMETRY_DISABLED=1 next build",
    "prebuild": "npm install next@14.2.35 --save-exact --no-save || true && npx prisma generate || true",
    "build:full": "node scripts/vercel-build.js",
    "build:vercel-old": "npx prisma generate && npx prisma migrate deploy || echo OK && npm run build",
    "build:vercel": "node scripts/build.js",
    "postinstall": "prisma generate && patch-package",
    "update-browserslist": "npx update-browserslist-db@latest",
    "clean": "rm -rf .next node_modules/.cache",
    "build:local": "npm run clean && npm run build",
    "start": "next start -p 3000",
    "start:lan": "next start -p 3000 -H 0.0.0.0",
    "start:local": "npm run clean && npm run build && (lsof -ti:3000 | xargs kill -9 2>/dev/null || true) && next start -p 3000",
    "lint": "eslint",
    "smoke-check": "node scripts/smoke-check.mjs",
    "db:seed": "tsx prisma/seed.ts",
    "db:migration:validate": "tsx scripts/validate-migration-cutoff.ts --strict && tsx scripts/validate-dual-track-migration-config.ts",
    "db:migrate:shared": "echo 'Shared Neon only — requires DATABASE_URL and human approval' && npx prisma migrate deploy --schema prisma/schema.prisma",
    "db:migrate:greenfield": "echo 'Use GREENFIELD_DATABASE_URL — never DATABASE_URL' && npx prisma migrate deploy --schema prisma/schema.prisma",
    "db:greenfield:bootstrap": "tsx scripts/run-disposable-greenfield-test.ts --mode dry-run",
    "db:greenfield:test": "tsx scripts/run-disposable-greenfield-test.ts --mode greenfield",
    "db:simulate:shared-neon": "tsx scripts/simulate-shared-neon-migration-options.ts",
    "validate:baseline": "tsx scripts/validate-current-state-baseline.ts",
    "validate:greenfield-safety": "tsx scripts/validate-disposable-greenfield-safety.ts",
    "validate:migration-cutoff": "tsx scripts/validate-migration-cutoff.ts",
    "validate:dual-track": "tsx scripts/validate-dual-track-migration-config.ts",
    "validate:no-auto-migrations-in-build": "tsx scripts/validate-no-auto-migrations-in-build.ts",
    "deploy": "npm run build && git add -A && git commit -m \"Deploy: $(date +'%Y-%m-%d %H:%M')\" && git push origin main && npx vercel --prod",
    "deploy:quick": "npx vercel --prod",
    "deploy:preview": "npx vercel",
    "test:account-normalization": "npx tsx scripts/test-account-email-normalization.ts",
    "test:adaptive-workspace": "npx tsx lib/adaptive-workspace/tests/run-tests.ts",
    "test:adaptive-workspace-react": "npx tsx lib/adaptive-workspace-react/tests/run-tests.ts",
    "test:adaptive-workspace-chrome": "npx tsx lib/adaptive-workspace-react/tests/run-chrome-occupancy-tests.ts",
    "test:adaptive-workspace-notifications": "npx tsx lib/adaptive-workspace-react/tests/run-notifications-shadow-tests.ts",
    "test:adaptive-workspace-messages": "npx tsx lib/adaptive-workspace-react/tests/run-messages-shadow-tests.ts",
    "test:adaptive-workspace-settings-on": "npx tsx lib/adaptive-workspace-react/tests/run-settings-on-pilot-tests.ts",
    "test:adaptive-workspace-settings-on-freeze": "npx tsx lib/adaptive-workspace-react/tests/run-settings-on-freeze-tests.ts",
    "test:adaptive-workspace-feed-compatibility": "npx tsx lib/adaptive-workspace-react/tests/run-feed-compatibility-audit-tests.ts",
    "test:adaptive-workspace-feed-sealed": "npx tsx lib/adaptive-workspace/tests/run-sealed-runtime-tests.ts && npx tsx lib/adaptive-workspace-react/tests/run-feed-sealed-runtime-tests.ts",
    "test:adaptive-workspace-feed-sealed-browser": "npx tsx lib/adaptive-workspace/tests/run-feed-freeze-proof-tests.ts",
    "probe:adaptive-workspace-feed-sealed": "node scripts/probe-feed-sealed-runtime-phase3b2.mjs",
    "probe:adaptive-workspace-feed-sealed-browser": "node scripts/run-feed-sealed-browser-proof-phase3b2.mjs",
    "probe:adaptive-workspace-settings-on": "node scripts/probe-settings-workspace-on-phase2g.mjs",
    "validate:adaptive-workspace-settings-shadow": "npx tsx scripts/validate-adaptive-workspace-settings-shadow.ts",
    "validate:adaptive-workspace-chrome-occupancy": "npx tsx scripts/validate-adaptive-workspace-chrome-occupancy.ts",
    "validate:adaptive-workspace-notifications-shadow": "npx tsx scripts/validate-adaptive-workspace-notifications-shadow.ts",
    "validate:adaptive-workspace-messages-shadow": "npx tsx scripts/validate-adaptive-workspace-messages-shadow.ts",
    "validate:adaptive-workspace-settings-on-pilot": "npx tsx scripts/validate-adaptive-workspace-settings-on-pilot.ts",
    "validate:adaptive-workspace-settings-on-freeze": "npx tsx scripts/validate-adaptive-workspace-settings-on-freeze.ts",
    "validate:adaptive-workspace-feed-compatibility": "npx tsx scripts/validate-adaptive-workspace-feed-compatibility-audit.ts",
    "validate:adaptive-workspace-feed-sealed": "npx tsx scripts/validate-adaptive-workspace-feed-sealed-runtime.ts",
    "validate:adaptive-workspace-feed-sealed-browser": "npx tsx scripts/validate-adaptive-workspace-feed-sealed-browser.ts",
    "test:display-name": "npx tsx scripts/test-display-name-preference.ts",
    "test:notifications-unread": "npx tsx scripts/test-notification-unread-logic.ts",
    "test:chat-config": "node scripts/test-chat-config.js",
    "test:pusher": "node scripts/test-pusher-connection.js",
    "debug:conversations": "node scripts/debug-conversation-participants.js",
    "test:participant-display": "node scripts/test-participant-display.js",
    "fix:participants": "node scripts/fix-participant-identification.js",
    "test:api-participants": "node scripts/test-api-participants.js",
    "test:user-identification": "node scripts/test-user-identification.js",
    "videos:transcode": "node scripts/transcode-existing-videos.js",
    "videos:transcode:run": "node scripts/transcode-existing-videos.js --run",
    "sync-android-splash": "node scripts/sync-android-splash-from-public.mjs",
    "cap:sync": "npm run sync-android-splash && npx cap sync",
    "cap:add:android": "npx cap add android",
    "cap:open:android": "npx cap open android",
    "cap:build:android": "npm run build && npm run cap:sync && npx cap open android",
    "release:android": "node scripts/release-android.mjs",
    "android:fingerprints": "node scripts/android-signing-fingerprints.mjs",
    "android:validate-google-services": "node scripts/validate-google-services.mjs",
    "perf:startup": "node scripts/performance/measure-homecheff-startup.mjs",
    "perf:startup:cold": "node scripts/performance/measure-homecheff-startup.mjs --mode=cold --runs=3",
    "perf:startup:warm": "node scripts/performance/measure-homecheff-startup.mjs --mode=warm --runs=3",
    "analyze": "cross-env ANALYZE=true npm run build"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/app": "8.1.0",
    "@capacitor/browser": "8.0.3",
    "@capacitor/core": "^8.3.1",
    "@capacitor/file-transfer": "2.0.4",
    "@capacitor/filesystem": "8.1.2",
    "@capacitor/geolocation": "^8.2.0",
    "@capacitor/push-notifications": "^8.0.3",
    "@capgo/capacitor-social-login": "^8.3.20",
    "@google-analytics/data": "^5.2.1",
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^6.15.0",
    "@react-pdf/renderer": "^4.3.2",
    "@stripe/stripe-js": "^7.9.0",
    "@types/geolib": "^2.0.3",
    "@types/socket.io-client": "^1.4.36",
    "@vercel/blob": "^2.0.1",
    "bcryptjs": "^3.0.2",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "emoji-picker-react": "^4.16.1",
    "firebase-admin": "^13.9.0",
    "form-data": "^4.0.4",
    "formdata-node": "^6.0.3",
    "formidable": "^3.5.4",
    "geolib": "^3.3.4",
    "google-auth-library": "^9.15.1",
    "lucide-react": "^0.542.0",
    "next": "14.2.35",
    "next-auth": "^4.24.11",
    "node-fetch": "^3.3.2",
    "prisma": "^6.15.0",
    "pusher": "^5.2.0",
    "pusher-js": "^8.4.0",
    "qrcode": "^1.5.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-qr-code": "^2.0.18",
    "react-zoom-pan-pinch": "^4.0.3",
    "resend": "^6.3.0",
    "server-only": "^0.0.1",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "stripe": "^18.5.0",
    "swr": "^2.3.6",
    "tailwind-merge": "^3.3.1",
    "twilio": "^5.10.5",
    "undici": "^7.15.0",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.1",
    "@next/bundle-analyzer": "^14.2.35",
    "@types/formidable": "^3.4.5",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.4.21",
    "cross-env": "^10.1.0",
    "eslint": "^9.34.0",
    "null-loader": "^4.0.1",
    "patch-package": "^8.0.1",
    "postcss": "^8.5.6",
    "puppeteer-core": "^23.11.1",
    "tailwindcss": "3.3.7",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.5",
    "typescript": "^5"
  },
  "resolutions": {
    "lightningcss": "false",
    "@tailwindcss/node": "false",
    "@tailwindcss/postcss": "false"
  },
  "overrides": {
    "lightningcss": "false",
    "@tailwindcss/node": "false",
    "@tailwindcss/postcss": "false",
    "tar": "^7.5.4"
  }
}
