# SSO HomeCheff + Growth (*.homecheff.eu): zelfde waarden op beide Vercel-projecten
# NEXTAUTH_SECRET=<dezelfde-secret>
# NEXTAUTH_URL=https://homecheff.eu   (hoofdsite) of https://growth.homecheff.eu (Growth)
# Publieke URL voor links in e-mail (aanbevolen naast NEXTAUTH_URL):
# NEXT_PUBLIC_APP_URL=https://homecheff.eu
# APP_URL=https://homecheff.eu
# Resend (transactioneel: verificatie, reset, notificaties)
# RESEND_API_KEY=re_...
# Optioneel: volledige From-header na domeinverificatie in Resend (alleen de waarde, géén "FROM_EMAIL=" ervoor)
# Default in code: HomeCheff <no-reply@homecheff.eu>
# FROM_EMAIL=HomeCheff <no-reply@homecheff.eu>
# Optioneel: log chatPushSenderAvatar true/false bij sendChatNotification (geen tokens/urls)
# CHAT_PUSH_SENDER_AVATAR_DEBUG=true
# Optioneel: NEXTAUTH_COOKIE_DOMAIN=.homecheff.eu  (default als NEXTAUTH_URL op *.homecheff.eu staat)
# Zelfde DATABASE_URL / DIRECT_URL als HomeCheff

# --- Phase 2 Google OAuth split (web ≠ native) ---
# Web NextAuth (preferred names; legacy GOOGLE_CLIENT_* still works):
# GOOGLE_WEB_CLIENT_ID=615612462371-r5ntdobrn3rtc01nckhpajdsrr6s4qd7.apps.googleusercontent.com
# GOOGLE_WEB_CLIENT_SECRET=<matching-secret-for-6156-only>
# GOOGLE_CLIENT_ID=…   # legacy alias for GOOGLE_WEB_CLIENT_ID
# GOOGLE_CLIENT_SECRET=…  # legacy alias for GOOGLE_WEB_CLIENT_SECRET
#
# Native / Capacitor / Firebase audience (server allowlist + public Capgo webClientId):
# GOOGLE_NATIVE_CLIENT_ID=372044866667-oj37snd1j7m7qhqf98cjhbtvbad1mfg2.apps.googleusercontent.com
# GOOGLE_NATIVE_CLIENT_IDS=…  # optional comma-separated extra Android audiences
# NEXT_PUBLIC_GOOGLE_NATIVE_CLIENT_ID=372044866667-oj37snd1j7m7qhqf98cjhbtvbad1mfg2.apps.googleusercontent.com
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=…  # legacy public Capgo id (treated as native, not web)
#
# Preview auth origin (host-only cookies):
# PREVIEW_AUTH_URL=https://homecheff-app-git-performance-0f5539-sergio-s-projects-f7b64ee1.vercel.app

# S3 configuratie (vervang deze waarden)
AWS_REGION=eu-central-1
AWS_S3_BUCKET=<<jouw_bucketnaam>>
AWS_ACCESS_KEY_ID=<<iam_access_key_id>>
AWS_SECRET_ACCESS_KEY=<<iam_secret_access_key>>

# Optioneel: toon native Capacitor GPS-testblok op de feed (alleen voor interne builds; niet op productie-Vercel)
# NEXT_PUBLIC_CAPACITOR_NATIVE_GPS_DEBUG=true

# Optioneel: toon native push-debug UI (FCM-token test); alleen met native app + dev of staging
# NEXT_PUBLIC_CAPACITOR_PUSH_DEBUG=true

# Android: download google-services.json (Firebase Console → Project → Android app eu.homecheff.mobile) naar:
#   android/app/google-services.json
# (bestand staat in .gitignore — niet committen)
# Play Open Testing: registreer ook Play App Signing SHA-1/SHA-256 in Firebase. Zie docs/ANDROID_GOOGLE_SIGNIN_PLAY.md
# npm run android:fingerprints && npm run android:validate-google-services

# Android release signing: plaats lokaal android/keystore.properties + android/homecheff-release-key.jks (zie .gitignore).

# Noodrem: skip native PushNotifications.register() in JS (testen zonder FCM); geen productie
# NEXT_PUBLIC_DISABLE_NATIVE_PUSH_REGISTER=true
# NEXT_PUBLIC_HC_DISABLE_PUSH_UPDATE_PROMPT=true
# Schakel het update-push-uitlegmodal uit (alleen debug als taps crashen).

# Optioneel: log visibility/pageshow in Capacitor WebView (resume / cold start debug)
# NEXT_PUBLIC_NATIVE_LIFECYCLE_DEBUG=true

# Google Play Open Testing (primary Android distribution)
NEXT_PUBLIC_GOOGLE_PLAY_OPEN_TESTING_URL=https://play.google.com/apps/testing/eu.homecheff.mobile
NEXT_PUBLIC_APP_DISTRIBUTION=play

# Android beta APK (legacy sideload — disabled for Play distribution)
# Standaard: `config/android-version.json` + `node scripts/release-android.mjs <versie> --apk`.
# Alleen Vercel zetten bij noodsituatie — env overschrijft altijd het JSON-bestand.
# NEXT_PUBLIC_ANDROID_BETA_APK_URL=https://…/homecheff-beta.apk
# NEXT_PUBLIC_ANDROID_BETA_VERSION=1.0.3
# APP_MIN_REQUIRED_ANDROID_VERSION=1.0.2
# APP_UPDATE_ENABLED=false
# APP_UPDATE_FORCE=false

# Fase 3B: premium-gating externe contactkanalen (standaard uit — geen fake locks)
# CONTACT_PREMIUM_GATING_ENABLED=true
