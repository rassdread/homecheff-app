<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <!-- Customize your theme here. -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
    </style>

    <!-- Light shell: DayNight kan op device-dark een donkere window/chrome geven vóór eerste Web-paint. -->
    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:background">@null</item>
        <!-- Voorkomt zwarte flash tussen splash-hide en eerste WebView-paint -->
        <item name="android:windowBackground">@android:color/white</item>
        <item name="android:statusBarColor">@android:color/white</item>
        <item name="android:navigationBarColor">@android:color/white</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">true</item>
    </style>


    <!--
      Android 12+: animatedIcon wordt door OEMs als adaptive/cirkel getoond — gebruik een vierkante PNG
      (splash_a12_safe_icon), geen layer-list (betrouwbaarder op cold start).
      Pre-12: android:windowBackground = splash_full (fullscreen portrait splash.png).
    -->
    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="android:windowBackground">@drawable/splash_full</item>
        <item name="windowSplashScreenBackground">@android:color/white</item>
        <item name="android:windowSplashScreenBackground">@android:color/white</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_a12_safe_icon</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/splash_a12_safe_icon</item>
        <item name="postSplashScreenTheme">@style/AppTheme.NoActionBar</item>
    </style>
</resources>