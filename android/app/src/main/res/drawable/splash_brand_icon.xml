<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 12+ SplashScreen API: achtergrond moet een effen kleur zijn (@android:color/white).
  Het merkbeeld komt via windowSplashScreenAnimatedIcon (gemaskerd door het systeem).
  Maximale aanbevolen icoon-oppervlak ~240dp; wit canvas + gecentreerde splash-bitmap.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:drawable="@android:color/white" />
    <item
        android:width="240dp"
        android:height="240dp"
        android:gravity="center">
        <bitmap
            android:gravity="center"
            android:src="@drawable/splash" />
    </item>
</layer-list>
